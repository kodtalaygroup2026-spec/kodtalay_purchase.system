# ===========================================================================
# ตัวอย่างไฟล์ Environment Variables — คัดลอกไฟล์นี้เป็น .env.local แล้วใส่ค่าจริง
# ห้าม commit ไฟล์ .env.local ขึ้น git เด็ดขาด (มี secret)
# ค่าทั้งหมดหาได้จาก Supabase Dashboard > Project Settings > API
# ===========================================================================

# URL ของโปรเจกต์ Supabase (เปิดเผยฝั่ง client ได้)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon/Public key — ใช้ฝั่ง browser ได้ เพราะถูกป้องกันด้วย Row Level Security (RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service Role key — มีสิทธิ์ข้าม RLS ทั้งหมด ใช้เฉพาะฝั่ง server เท่านั้น
# ห้ามนำขึ้น client หรือ prefix ด้วย NEXT_PUBLIC_ เด็ดขาด
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LINE Messaging API — ใช้ส่ง notification ผ่าน API Route เท่านั้น
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token

# URL ของแอปพลิเคชัน (ใช้ใน LINE notification link)
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
